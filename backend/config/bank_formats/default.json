{
  "bank_id": "default",
  "name": "Generic Bank Statement",
  "keywords": [],
  "key_value_patterns": {
    "account_number": [
      "account\\s*(?:no\\.?|number)\\s*[:=]?\\s*([0-9\\-]+)",
      "a/c\\s*(?:no\\.?)?\\s*[:=]?\\s*([0-9\\-]+)"
    ],
    "opening_balance": [
      "opening\\s*balance\\s*[:=]?\\s*([\\d,.\\(\\)\\-]+)",
      "opening\\s*bal\\.?\\s*[:=]?\\s*([\\d,.\\(\\)\\-]+)"
    ],
    "closing_balance": [
      "closing\\s*balance\\s*[:=]?\\s*([\\d,.\\(\\)\\-]+)",
      "closing\\s*bal\\.?\\s*[:=]?\\s*([\\d,.\\(\\)\\-]+)"
    ],
    "statement_period": [
      "statement\\s*period\\s*[:=]?\\s*([0-9]{1,2}[-/][0-9]{1,2}[-/][0-9]{2,4})\\s*to\\s*([0-9]{1,2}[-/][0-9]{1,2}[-/][0-9]{2,4})",
      "period\\s*[:=]?\\s*([0-9]{1,2}[-/][A-Za-z]{3,9}[-/][0-9]{2,4})\\s*[-to]+\\s*([0-9]{1,2}[-/][A-Za-z]{3,9}[-/][0-9]{2,4})"
    ]
  },
  "table_column_mapping": {},
  "date_formats": [
    "%d-%b-%Y",
    "%d/%m/%Y",
    "%Y-%m-%d",
    "%d-%m-%Y",
    "%d %b %Y",
    "%d-%B-%Y",
    "%d/%m/%y",
    "%d-%b-%y"
  ],
  "amount_cleanup": {
    "currency_symbols": ["₦", "NGN", "N"],
    "negative_indicators": ["(", ")", "-"]
  }
}
